@page
@using Metalama.Backstage.Licensing
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model CommunityModel

<p>
    Metalama Community is available for select use cases. Which one do you qualify for?
</p>

<form method="post">
    <div class="radio">
        <div class="label">
            <label>
                <input type="radio" asp-for="UseKind" value="@CommunityLicenseReason.Individual">
                I am an individual developer and I will not use Metalama as part of any employment contract
                (freelance is okay).
            </label>
        </div>
    </div>
    
    <div class="radio">
        <div class="label">
            <label>
                <input type="radio" asp-for="UseKind" value="@CommunityLicenseReason.NonCommercial">
                I will use Metalama for non-commercial purposes only.
            </label>
        </div>
    </div>

    <div class="radio">
        <div class="label">
            <label>
                <input type="radio" asp-for="UseKind" value="@CommunityLicenseReason.OpenSource">
                I will use Metalama to develop open-source software.
            </label>
        </div>
    </div>

    <div class="radio">
        <div class="label">
            <label>
                <input type="radio" asp-for="UseKind" value="@CommunityLicenseReason.SmallBusiness">
                No more than 3 developers will use Metalama on the same day.
            </label>
        </div>
    </div>

    <div class="radio">
        <div class="label">
            <label>
                <input type="radio" asp-for="UseKind" value="@CommunityLicenseReason.None">
                None of the above.
            </label>
        </div>
    </div>

    <div class="continue-button">
        <button type="submit">Continue</button>
    </div>
</form>

@foreach (var error in Model.ErrorMessages)
{
    <div class="text-danger">
        @error
    </div>
}

<div asp-validation-summary="ModelOnly" class="text-danger"></div>