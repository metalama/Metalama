@page
@using Metalama.Backstage.Telemetry
@using Metalama.Backstage.UserInterface
@model PrivacyPageModel
@inject WebLinks WebLinks;

@section Scripts {
    <script>
        $(document).ready(function () {
            // Auto-save when the usage checkbox or any of the exception/performance radio buttons change.
            $('#isUsageReportingEnabledCheckbox, input[name="ExceptionConsent"], input[name="PerformanceConsent"]').change(function () {
                $('form').submit();
            });
        });
    </script>
}

<form method="post">
    <h3>Telemetry and Privacy Options</h3>
    <p>
        To improve the product, Metalama can collect anonymous data. You can change your choices at any time.
        Read more in our <a href="@WebLinks.PrivacyPolicy" target="_blank">Privacy Policy</a> and the
        <a href="@WebLinks.DisableTelemetryInstructions" target="_blank">telemetry documentation</a>.
    </p>

    <div class="checkbox">
        <input id="isUsageReportingEnabledCheckbox" type="checkbox" asp-for="IsUsageReportingEnabled">
        <div class="label">
            <label asp-for="IsUsageReportingEnabled">
                Send anonymous usage data to help improve Metalama.
            </label>
            <small>Anonymous statistics about which features are used. Reports include a randomly generated device ID
                that you can reset at any time.</small>
            @if (Model.IsTelemetryActivated)
            {
                <div class="device-id-action">
                    <button type="submit" class="link-button" asp-page-handler="ResetDeviceId" title="Your device ID is rotated every first Monday of the month.">Reset device ID now</button>
                    @if (Model.IsDeviceIdReset)
                    {
                        <span class="text-success">Your device ID has been reset.</span>
                    }
                </div>
            }
        </div>
    </div>

    <h4>Exception reports</h4>
    <p>Reports of unhandled exceptions, which may include code-related diagnostic details.</p>
    <div class="radio-group compact">
        <div class="radio-option">
            <input type="radio" id="exceptionAsk" name="ExceptionConsent" value="@TelemetryConsent.Default"
                   checked="@( Model.ExceptionConsent == TelemetryConsent.Default )">
            <label for="exceptionAsk">
                <strong>Ask me each time (recommended)</strong>
                <small>The report is captured locally and a notification lets you review it before anything is
                    sent.</small>
            </label>
        </div>

        <div class="radio-option">
            <input type="radio" id="exceptionSend" name="ExceptionConsent" value="@TelemetryConsent.Yes"
                   checked="@( Model.ExceptionConsent == TelemetryConsent.Yes )">
            <label for="exceptionSend">
                <strong>Send automatically</strong>
                <small>Reports are captured and sent without asking.</small>
            </label>
        </div>

        <div class="radio-option">
            <input type="radio" id="exceptionNever" name="ExceptionConsent" value="@TelemetryConsent.No"
                   checked="@( Model.ExceptionConsent == TelemetryConsent.No )">
            <label for="exceptionNever">
                <strong>Never send</strong>
                <small>Nothing is captured and you are never asked.</small>
            </label>
        </div>
    </div>

    <h4>Performance reports</h4>
    <p>Reports of performance problems, which may include code-related diagnostic details.</p>
    <div class="radio-group compact">
        <div class="radio-option">
            <input type="radio" id="performanceAsk" name="PerformanceConsent" value="@TelemetryConsent.Default"
                   checked="@( Model.PerformanceConsent == TelemetryConsent.Default )">
            <label for="performanceAsk">
                <strong>Ask me each time (recommended)</strong>
                <small>The report is captured locally and a notification lets you review it before anything is
                    sent.</small>
            </label>
        </div>

        <div class="radio-option">
            <input type="radio" id="performanceSend" name="PerformanceConsent" value="@TelemetryConsent.Yes"
                   checked="@( Model.PerformanceConsent == TelemetryConsent.Yes )">
            <label for="performanceSend">
                <strong>Send automatically</strong>
                <small>Reports are captured and sent without asking.</small>
            </label>
        </div>

        <div class="radio-option">
            <input type="radio" id="performanceNever" name="PerformanceConsent" value="@TelemetryConsent.No"
                   checked="@( Model.PerformanceConsent == TelemetryConsent.No )">
            <label for="performanceNever">
                <strong>Never send</strong>
                <small>Nothing is captured and you are never asked.</small>
            </label>
        </div>
    </div>

    @if (Model.IsSaved)
    {
        <p class="text-success">Your preference has been saved.</p>
    }

    <div class="navigation-buttons" style="justify-content: flex-start;">
        <div class="back-button">
            <a href="/">&larr; Back</a>
        </div>
    </div>
</form>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
