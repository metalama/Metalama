@page
@using Metalama.Backstage.UserInterface
@model ConsentsPageModel
@inject WebLinks WebLinks;

<form method="post">
    <div class="checkbox">
        <input type="checkbox" asp-for="AcceptLicense ">
        <div class="label">
            <label asp-for="AcceptLicense ">
                I accept the terms of the <a href="@WebLinks.LicenseAgreement" target="_blank">License Agreement</a> and
                the <a href="@WebLinks.PrivacyPolicy" target="_blank">Privacy Policy</a>. I understand
                that the software is subject to License Audit and I consent with the collection of usage data.
            </label>
        </div>
    </div>

    <div class="navigation-buttons">
        <div class="back-button">
            <a href="@Model.BackUrl">&larr; Back</a>
        </div>
        <div class="continue-button">
            <button type="submit">Continue</button>
        </div>
    </div>

</form>


@foreach (var error in Model.ErrorMessages)
{
    <div class="text-danger">
        @error
    </div>
}

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
