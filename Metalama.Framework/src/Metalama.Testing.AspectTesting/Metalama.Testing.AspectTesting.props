<Project>
    <PropertyGroup>
        <!-- We disable Metalama unconditionally, because referenced projects alphabetically ordered after "Metalama" may inadvertently enable Metalama again. -->
        <MetalamaEnabled>False</MetalamaEnabled>
        <StartupObject Condition="$(TargetFramework.Contains('.'))">AutoGeneratedProgram</StartupObject>

        <!-- If the build is deterministic, we can have the error : SourceRoot items must include at least one top-level (not nested) item 
             when DeterministicSourcePaths is true -->
        <Deterministic>False</Deterministic>

        <!-- AssemblyInfo attributes are used to pass info from the msbuild project to the test project. -->
        <GenerateAssemblyInfo>True</GenerateAssemblyInfo>

        <MetalamaTestProjectDirectory Condition="'$(MetalamaTestProjectDirectory)'==''">$(MSBuildProjectDirectory)</MetalamaTestProjectDirectory>
        
    </PropertyGroup>

    <!-- Enable dynamic file nesting in Visual Studio -->
    <ItemGroup>
        <ProjectCapability Include="ConfigurableFileNesting" />
        <ProjectCapability Include="ConfigurableFileNestingFeatureEnabled" />
    </ItemGroup>

    <!--
        Exclude test infrastructure references from test compilations (issue #754).
        Test input files are compiled as standalone mini-projects and should only receive
        references that a real user project would have, not the full set of references
        from the test project (xUnit, test SDK, mocking libraries, etc.).

        Users can customize exclusions by adding/removing MetalamaTestExcludedReference items
        in their project file. Since this is in .props, Remove works from .csproj.
    -->
    <ItemGroup>
        <!-- Test frameworks -->
        <MetalamaTestExcludedReference Include="xunit" />
        <MetalamaTestExcludedReference Include="xunit.abstractions" />
        <MetalamaTestExcludedReference Include="xunit.extensibility.core" />
        <MetalamaTestExcludedReference Include="xunit.extensibility.execution" />
        <MetalamaTestExcludedReference Include="xunit.runner.visualstudio" />
        <!-- Test SDK and platform -->
        <MetalamaTestExcludedReference Include="Microsoft.NET.Test.Sdk" />
        <MetalamaTestExcludedReference Include="Microsoft.TestPlatform.TestHost" />
        <MetalamaTestExcludedReference Include="Microsoft.TestPlatform.ObjectModel" />
        <!-- Mocking libraries -->
        <MetalamaTestExcludedReference Include="FakeItEasy" />
        <MetalamaTestExcludedReference Include="FakeItEasy.Analyzer.CSharp" />
        <!-- Test utilities that are not part of the user-facing API -->
        <MetalamaTestExcludedReference Include="Metalama.Backstage.Testing" />
        <MetalamaTestExcludedReference Include="coverlet.collector" />
    </ItemGroup>

</Project>