<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net8.0-windows</TargetFramework>
        <Nullable>enable</Nullable>
        <UseWPF>true</UseWPF>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="CompiledBindings.WPF" />
        <PackageReference Include="Metalama.Framework" />
    </ItemGroup>

    <!-- Force GenerateMSBuildEditorConfigFile to run before WPF code generation -->
    <Target Name="EnsureEditorConfigBeforeWpf" BeforeTargets="MarkupCompilePass1" DependsOnTargets="GenerateMSBuildEditorConfigFile" />

</Project>
