<Window x:Class="Issue1585.SelectSettingsWindowControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Issue1585.Converters"
        Title="Repro" Height="200" Width="300">
    <Window.Resources>
        <!-- Referencing the hand-written converter is what triggers MC3074 when the temp compile fails. -->
        <converters:EnumToStringConverter x:Key="EnumToStringConverter" />
    </Window.Resources>
    <Grid>
        <TextBlock Text="{Binding Name, Converter={StaticResource EnumToStringConverter}}" />
    </Grid>
</Window>
