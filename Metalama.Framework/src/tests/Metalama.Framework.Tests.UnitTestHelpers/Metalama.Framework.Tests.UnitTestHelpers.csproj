<Project>

    <Import Project="Sdk.props" Sdk="Microsoft.NET.Sdk" Condition="$(MSBuildThisFileFullPath) == $(MSBuildProjectFullPath)" />

    <Import Project="../../../build/RoslynVersion/Latest.imports" />

    <PropertyGroup>
        <TargetFrameworks>net48;net8.0</TargetFrameworks>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <IsPackable>true</IsPackable>
        <RootNamespace>Metalama.Framework.Tests.UnitTestHelpers</RootNamespace>
        <AssemblyName>Metalama.Framework.Tests.UnitTestHelpers.$(ThisRoslynVersionNoPreview)</AssemblyName>
        <PackageId>Metalama.Framework.Tests.UnitTestHelpers</PackageId>
        <!-- It must be preview and not 12.0 because of Rider. -->
        <LangVersion>preview</LangVersion>
        <!-- 
            There is intentionally no override of LangVersion for previous Roslyn tests as compilations created by test helpers have correct language version set.
            This way we can use asserts in the latest language. To differentiate tests, use ROSLYN_X_Y_OR_GREATER.
        -->
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\Metalama.Framework.Engine$(ThisRoslynVersionProjectSuffix)\Metalama.Framework.Engine$(ThisRoslynVersionProjectSuffix).csproj" PrivateAssets="all" />
        <ProjectReference Include="..\..\Metalama.Framework.DesignTime$(ThisRoslynVersionProjectSuffix)\Metalama.Framework.DesignTime$(ThisRoslynVersionProjectSuffix).csproj" PrivateAssets="all" />
        <ProjectReference Include="..\..\Metalama.Testing.UnitTesting$(ThisRoslynVersionProjectSuffix)\Metalama.Testing.UnitTesting$(ThisRoslynVersionProjectSuffix).csproj" />

        <!-- Dependency of the resulting package should be on Implementation package. -->
        <ProjectReference Condition="$(ThisRoslynVersion) == $(RoslynApiMaxVersion)" Include="..\..\Metalama.Framework.Implementation.Package/Metalama.Framework.Implementation.Package.csproj" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="Metalama.Framework.Tests.UnitTests.$(ThisRoslynVersionNoPreview)" />
    </ItemGroup>

    <Import Project="Sdk.targets" Sdk="Microsoft.NET.Sdk" Condition="$(MSBuildThisFileFullPath) == $(MSBuildProjectFullPath)" />

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="\" />
    </ItemGroup>


</Project>
