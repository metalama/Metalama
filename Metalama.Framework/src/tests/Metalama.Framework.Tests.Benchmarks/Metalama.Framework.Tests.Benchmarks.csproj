<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>12.0</LangVersion>
        <!-- These are public Microsoft.CodeAnalysis packages, so they must not follow the global RoslynVersion (the Metalama.Compiler fork's internal, possibly-unpublished Roslyn). -->
        <BenchmarkRoslynVersion Condition="'$(BenchmarkRoslynVersion)'==''">$(RoslynApiMaxVersion)</BenchmarkRoslynVersion>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="BenchmarkDotNet" />
      <PackageReference Include="JetBrains.Profiler.Api" />
      <PackageReference Include="Microsoft.CodeAnalysis.Workspaces.MSBuild" VersionOverride="$(BenchmarkRoslynVersion)" />
      <PackageReference Include="Microsoft.CodeAnalysis.Workspaces.Common" VersionOverride="$(BenchmarkRoslynVersion)" />
      <PackageReference Include="Microsoft.CodeAnalysis.CSharp" VersionOverride="$(BenchmarkRoslynVersion)" />
      <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Features" VersionOverride="$(BenchmarkRoslynVersion)" />
      <PackageReference Include="Microsoft.CodeAnalysis" VersionOverride="$(BenchmarkRoslynVersion)" />
      <PackageReference Include="Microsoft.Build.Locator" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="../../Metalama.Framework.Engine$(EngineProjectSuffix)/Metalama.Framework.Engine$(EngineProjectSuffix).csproj" />
      <ProjectReference Include="../../Metalama.Testing.UnitTesting$(EngineProjectSuffix)/Metalama.Testing.UnitTesting$(EngineProjectSuffix).csproj" />

       <!-- Override dependencies to avoid vulnerability warnings. -->
       <PackageReference Include="System.Text.Json" VersionOverride="$(SystemTextJsonLatestVersion)" />

    </ItemGroup>

</Project>
