<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net8.0</TargetFramework>
        <AssemblyName>metalama</AssemblyName>
        <PackageId>Metalama.Tool</PackageId>
        <RootNamespace>Metalama.Tool</RootNamespace>
        
        <!--
        Disable globalization so users on Linux do not have to install the lib-icu library.
        https://aka.ms/dotnet-missing-libicu
         -->
        <InvariantGlobalization>True</InvariantGlobalization>
		
		<!--
        CSC : warning CS8002: Referenced assembly 'Spectre.Console.Cli, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null' does not have a strong name.
        CSC : warning CS8002: Referenced assembly 'Spectre.Console, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null' does not have a strong name.
		-->

		<NoWarn>$(NoWarn);CS8002</NoWarn>

        <!-- Avoid error NU5017: Cannot create a package that has no dependencies nor content. -->
        <DebugType>Portable</DebugType>
        
        <!-- Disable nuspec customization done by Metalama.Compiler.SDK. -->
        <MetalamaCompilerDisablePackCustomization>True</MetalamaCompilerDisablePackCustomization>
    </PropertyGroup>

    <PropertyGroup>
        <EnableNETAnalyzers>true</EnableNETAnalyzers>
        <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
        <WarningLevel>4</WarningLevel>
        <PackAsTool>true</PackAsTool>
        <ToolCommandName>metalama</ToolCommandName>
		<PackageDescription>A Metalama command line tool. Used for registering a license key or accessing some configuration settings.</PackageDescription>
        <RollForward>Major</RollForward>
        
        <!-- Tool NuGet package includes pdb files, .snupkg will get rejected because of duplicitous PDBs when publishing. -->
        <IncludeSymbols>false</IncludeSymbols>
    </PropertyGroup>

    <ItemGroup>
        <None Include="$(MsBuildThisFileDirectory)README.md" Pack="true" PackagePath="/" />
    </ItemGroup>
    
    <ItemGroup>
        <PackageReference Include="LibGit2Sharp" />
        <PackageReference Include="Metalama.Backstage.Commands" />
        <PackageReference Include="Microsoft.Extensions.Logging.Console" />
        <PackageReference Include="Metalama.Compiler.Sdk"/>
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" ExcludeAssets="all"/>
        <PackageReference Include="Microsoft.CodeAnalysis.Common" ExcludeAssets="all"/>
    </ItemGroup>
    
    <ItemGroup>
      <ProjectReference Include="..\Metalama.Framework.ConfigurationFiles\Metalama.Framework.ConfigurationFiles.csproj" PrivateAssets="none" />
    </ItemGroup>

    <Target Name="_ExcludePackageFiles" AfterTargets="Build" BeforeTargets="GenerateNuspec">
        <ItemGroup>
            <!-- Exclude full pdbs from packing so the .snupkg doesn't get refused by nuget.org. -->
            <_PackageFilesToExclude Include="bin/$(Configuration)/**/*.pdb" />
            <!-- Exclude xml for smaller files. -->
            <_PackageFilesToExclude Include="bin/$(Configuration)/**/*.xml" />
        </ItemGroup>
    </Target>


</Project>

