<Project>

    <PropertyGroup Condition="'$(MetalamaEnabled)'!='False'">
        <!-- Define a METALAMA compilation symbol (aka constant). -->
        <DefineConstants>$(DefineConstants);METALAMA</DefineConstants>

        <!-- Auxiliary files used at design time. -->
        <MetalamaAdditionalCompilationOutputDirectory Condition="'$(MetalamaDesignTimeEnabled)'=='False'">$(MSBuildProjectDirectory)/$(IntermediateOutputPath)/metalama-aux/</MetalamaAdditionalCompilationOutputDirectory>

        <!-- Design time fallback dependency that forces rerun of analyzers/source generators when changed. -->
        <MetalamaDesignTimeFallbackTouchFile Condition="'$(MetalamaDesignTimeEnabled)'=='False'">$(MetalamaAdditionalCompilationOutputDirectory)MetalamaDesignTimeTouch.touch</MetalamaDesignTimeFallbackTouchFile>

        <!-- Define a new build configuration named LamaDebug (configured below).
             This needs to be done in the targets file, and not in the props file, because Microsoft.NET.Sdk.props will not define it if we define it first in our own props file. -->
        <Configurations Condition="'$(MetalamaCreateLamaDebugConfiguration)'!='False'">$(Configurations);LamaDebug</Configurations>

        <!-- If this is a compile-time project, do not remove compile-time-only code. -->
        <MetalamaRemoveCompileTimeOnlyCode Condition="'$(MetalamaCompileTimeProject)'=='True'">False</MetalamaRemoveCompileTimeOnlyCode>

        <!-- Convert items to properties -->
        <!-- We use ',' as a list item separator and '|' as a separator within a list. We don't use ';' because it means a comment in .editorconfig -->
        <MetalamaCompileTimePackages>@(MetalamaCompileTimePackage, ',')</MetalamaCompileTimePackages>
        <MetalamaCompileTimeAssemblies>@(MetalamaCompileTimeAssembly -> '%(FullPath)', ',')</MetalamaCompileTimeAssemblies>
        <MetalamaSourceGeneratorAttributes>@(MetalamaSourceGeneratorAttribute, ',')</MetalamaSourceGeneratorAttributes>
        <MetalamaExtensionAssemblies>@(MetalamaExtensionAssembly -> '%(FullPath)|%(TargetFramework)|%(TargetRoslynVersion)', ',')</MetalamaExtensionAssemblies>
        <MetalamaDesignTimeExtensionAssemblies>@(MetalamaDesignTimeExtensionAssembly -> '%(FullPath)|%(TargetFramework)|%(TargetRoslynVersion)', ',')</MetalamaDesignTimeExtensionAssemblies>

        <!-- Elevating CS8032: An instance of analyzer X cannot be created. 
             We elevate this warning to an error because otherwise, if Metalama.Framework fails to load, the compilation will be incorrect while there
             will be no warning. Troubleshooting this issue may be very complex without a real error.     -->
        <WarningsAsErrors>$(WarningsAsErrors);CS8032</WarningsAsErrors>

    </PropertyGroup>

    <!-- Default MetalamaFormatOutput to True when MetalamaDebugTransformedCode is True.
         This must be in the .targets file (not .props) so it can see properties set in the project file. -->
    <PropertyGroup Condition="'$(MetalamaDebugTransformedCode)'=='True'">
        <MetalamaFormatOutput Condition="'$(MetalamaFormatOutput)'==''">True</MetalamaFormatOutput>
    </PropertyGroup>

    <!-- For WPF projects, default IncludePackageReferencesDuringMarkupCompilation to true so that
         Metalama runs in the temporary assembly that MarkupCompilePass1 builds via
         GenerateTemporaryTargetAssembly. Without this, the temp compile excludes PackageReferences
         (and therefore Metalama analyzers/targets), so XAML references to aspect-introduced members
         fail with CS0117/CS1061, which cascades into MC3074. The known tradeoff is that the
         Metalama pipeline runs twice per WPF build (once in the temp compile, once in the real
         one); this matches the default modern .NET SDK WPF projects already use. The default
         is user-overridable, but an explicit false is rejected by MetalamaCheckMarkupCompilation
         (below) since it is incompatible with Metalama in a WPF project.
         See https://github.com/metalama/Metalama/issues/1588. -->
    <PropertyGroup Condition="'$(UseWPF)'=='true' AND '$(MetalamaEnabled)'!='False'">
        <IncludePackageReferencesDuringMarkupCompilation Condition="'$(IncludePackageReferencesDuringMarkupCompilation)'==''">true</IncludePackageReferencesDuringMarkupCompilation>
    </PropertyGroup>

    <!-- Inside the WPF MarkupCompilePass1 temporary assembly (project name suffix _wpftmp), switch Metalama
         to the WpfPrecompile compilation scenario. The pipeline then emits aspect-introduced member signatures
         only and skips the linker, since the temp assembly is consumed only by the XAML compiler for type
         resolution and then discarded. The full linker still runs in the real compile pass that follows.
         The user can override by setting MetalamaCompilationScenario explicitly. See https://github.com/metalama/Metalama/issues/1590. -->
    <PropertyGroup Condition="'$(UseWPF)'=='true' AND '$(MetalamaEnabled)'!='False' AND '$(MetalamaCompilationScenario)'==''">
        <MetalamaCompilationScenario Condition="$(MSBuildProjectName.EndsWith('_wpftmp'))">WpfPrecompile</MetalamaCompilationScenario>
    </PropertyGroup>

      <!-- The LangVersionImplicitlySet property is set by Metalama.Compiler when LangVersion is not defined, according to the current target framework.
         We change this value to our own lowest supported version. 
        -->
    <PropertyGroup Condition="'$(LangVersionImplicitlySet)'=='True' AND '$(LangVersion)'!='12.0' AND '$(LangVersion)'!='13.0' AND '$(LangVersion)'!='14.0' AND '$(LangVersion)'!='default' AND '$(LangVersion)'!='latest' AND '$(LangVersion)'!='latestMajor' AND '$(LangVersion)'!='preview'">
        <_LangVersionBeforeMetalamaFix>$(LangVersion)</_LangVersionBeforeMetalamaFix>
        <LangVersion>12.0</LangVersion>
    </PropertyGroup>





    <ItemGroup Condition="'$(MetalamaCompileTimeProject)'=='True'">
        <AssemblyAttributes Include="Metalama.Framework.Aspects.CompileTimeAttribute"/>
    </ItemGroup>

    <ItemGroup Condition="'$(DesignTimeBuild)' == 'True' AND '$(MetalamaDesignTimeEnabled)'=='False'">
        <AdditionalFiles Include="$(MetalamaDesignTimeFallbackTouchFile)" Visible="False" />
    </ItemGroup>

    <Target Name="GetRestoreSources" BeforeTargets="PrepareForBuild" DependsOnTargets="_GetRestoreSettings" Condition="$(IsRestoreTargetsFileLoaded)=='true'">
        <PropertyGroup>
            <MetalamaRestoreSources>$(_OutputSources)</MetalamaRestoreSources>
        </PropertyGroup>
    </Target>

    <!-- Both touch files live under $(IntermediateOutputPath) so they are TFM-specific. Multi-targeted
         projects build their TFMs in parallel; sharing a single file across TFMs (as we briefly did under
         $(BaseIntermediateOutputPath) for the source-generator touch file) causes MSB3371 file-lock
         collisions. See https://github.com/metalama/Metalama/issues/1597.
         If $(IntermediateOutputPath) is undefined (e.g. when the .NET SDK has not yet resolved), the
         path properties stay empty and CreateMetalamaTouchFiles is skipped — IProjectOptions
         tolerates a null SourceGeneratorTouchFile/BuildTouchFile. -->
    <Target Name="ExportMetalamaFrameworkProperties" BeforeTargets="PrepareForBuild" Condition="'$(IntermediateOutputPath)'!=''">
        <PropertyGroup>
            <MetalamaBuildTouchFile>$([System.IO.Path]::Combine($(MSBuildProjectDirectory),$(IntermediateOutputPath),'MetalamaBuild.touch'))</MetalamaBuildTouchFile>
            <MetalamaSourceGeneratorTouchFile>$([System.IO.Path]::Combine($(MSBuildProjectDirectory),$(IntermediateOutputPath),'MetalamaSourceGenerator.g.cs'))</MetalamaSourceGeneratorTouchFile>
        </PropertyGroup>
    </Target>

    <Target Name="CreateMetalamaTouchFiles" BeforeTargets="BeforeCompile" Condition="'$(MetalamaBuildTouchFile)'!='' AND '$(MetalamaSourceGeneratorTouchFile)'!=''">
        <!-- MetalamaBuildTouchFile signals the design-time pipeline that a build has started. The design-time
             pipeline deletes it when it has observed a source change; AlwaysCreate without overwrite preserves
             incremental builds. It is registered as <AdditionalFiles> only so the compiler picks up its
             existence — the pipeline observes it through its own filesystem watcher, not through Roslyn. -->
        <Touch Files="$(MetalamaBuildTouchFile)" AlwaysCreate="true"/>

        <!-- MetalamaSourceGeneratorTouchFile is a .cs file included in <Compile> whose TouchId GUID the
             design-time pipeline rewrites whenever it produces a new compilation. Using <Compile> rather than
             <AdditionalFiles> ensures Rider and VS observe the change (see RIDER-75959, dotnet/roslyn#74716,
             https://github.com/metalama/Metalama/issues/831) and rerun the source generator. The class is
             [Obsolete(..., true)] so user code cannot reference it — that prevents any name collision when two
             projects share internals via [InternalsVisibleTo].

             The stub written below is the minimal valid syntax tree that satisfies the compiler on the very
             first build (before the pipeline has run); the pipeline then overwrites it with the canonical
             multi-line form on every run. Overwrite="false" preserves the pipeline's content across builds.
             ';' is escaped as '%3B' so MSBuild doesn't split the Lines value on it. -->
        <WriteLinesToFile File="$(MetalamaSourceGeneratorTouchFile)"
                          Lines="namespace Metalama.Internal { [global::System.Obsolete(&quot;Design-time only. Do not reference.&quot;, true)] internal static class MetalamaSourceGeneratorMarker { public const string TouchId = &quot;&quot;%3B } }"
                          Overwrite="false"/>

        <ItemGroup>
            <AdditionalFiles Include="$(MetalamaBuildTouchFile)" Visible="False"/>
            <Compile Include="$(MetalamaSourceGeneratorTouchFile)" Visible="False"/>
            <Clean Include="$(MetalamaBuildTouchFile)"/>
            <Clean Include="$(MetalamaSourceGeneratorTouchFile)"/>
        </ItemGroup>
    </Target>

    <Target Name="GatherCompilerVisibleProperties" BeforeTargets="GenerateMSBuildEditorConfigFileCore">
        <!-- This is only required for Roslyn 4.0, which doesn't have AnalyzerConfigOptions.Keys. -->
        <PropertyGroup>
            <MetalamaCompilerVisiblePropertiesList>@(CompilerVisibleProperty, ',')</MetalamaCompilerVisiblePropertiesList>
        </PropertyGroup>
        <ItemGroup>
            <CompilerVisibleProperty Include="MetalamaCompilerVisiblePropertiesList"/>
        </ItemGroup>
    </Target>

     <Target Name="CheckMetalamaAssemblyReferencePaths" BeforeTargets="BeforeCompile">
    
         <ItemGroup>
            <_InvalidPath Include="@(MetalamaCompileTimePackages)"  Condition="$([System.String]::Copy('%(FullPath)').Contains(`,`)) OR $([System.String]::Copy('%(FullPath)').Contains(`|`))" />
            <_InvalidPath Include="@(MetalamaCompileTimeAssemblies)"  Condition="$([System.String]::Copy('%(FullPath)').Contains(`,`)) OR $([System.String]::Copy('%(FullPath)').Contains(`|`))" />
            <_InvalidPath Include="@(MetalamaSourceGeneratorAttribute)"  Condition="$([System.String]::Copy('%(FullPath)').Contains(`,`)) OR $([System.String]::Copy('%(FullPath)').Contains(`|`))" />
            <_InvalidPath Include="@(MetalamaExtensionAssemblies)"  Condition="$([System.String]::Copy('%(FullPath)').Contains(`,`)) OR $([System.String]::Copy('%(FullPath)').Contains(`|`))" />
            <_InvalidPath Include="@(MetalamaDesignTimeExtensionAssemblies)" Condition="$([System.String]::Copy('%(FullPath)').Contains(`,`)) OR $([System.String]::Copy('%(FullPath)').Contains(`|`))" />
        </ItemGroup>

        <!-- Emit an error if there are invalid items -->
        <Error Text="The item '%(_InvalidPath.Identity)' has a FullPath containing an invalid character ('|' or ',')." 
            Condition="@(_InvalidPath->Count()) > 0" />
  </Target>

   <Target Name="MetalamaCheckLangVersion" BeforeTargets="CoreCompile">
    <Warning
      Text="The C# language version of the current project was updated from $(_LangVersionBeforeMetalamaFix) to $(LangVersion) despite the project targeting $(TargetFramework) because $(LangVersion) is the lowest version supported by Metalama Framework. To use C# $(LangVersion) features in $(TargetFramework), add a package like Polyfill. To suppress this warning, set &lt;LangVersion&gt; to at least $(LangVersion) in your project file."
       Condition="'$(_LangVersionBeforeMetalamaFix)' != ''"
      />
  </Target>

  <!-- Reject IncludePackageReferencesDuringMarkupCompilation=false in WPF + Metalama projects.
       That setting excludes PackageReferences (and therefore Metalama) from the WPF MarkupCompilePass1
       temp assembly, so XAML references to aspect-introduced members fail with CS0117/CS1061 and
       cascade into MC3074. Failing fast with a clear error is friendlier than the cascading XAML errors. -->
  <Target Name="MetalamaCheckMarkupCompilation" BeforeTargets="MarkupCompilePass1">
    <Error
      Text="IncludePackageReferencesDuringMarkupCompilation is set to 'false' in a WPF project that uses Metalama. This excludes Metalama from the temporary assembly that WPF builds for MarkupCompilePass1, which causes XAML references to aspect-introduced members to fail. Remove the explicit 'false' (or set it to 'true') to let Metalama run in the temp compile."
      Condition="'$(UseWPF)'=='true' AND '$(MetalamaEnabled)'!='False' AND '$(IncludePackageReferencesDuringMarkupCompilation)'=='false'" />
  </Target>
    
</Project>
